# Desabilita cache do servidor LiteSpeed (Hostinger)
<IfModule LiteSpeed>
  CacheLookup off
</IfModule>

# Desabilita cache do servidor Apache
<IfModule mod_cache.c>
  CacheDisable /
</IfModule>

<IfModule mod_headers.c>

  # HTML, JS, CSS e imagens — Safari no iPhone respeita esses headers
  <FilesMatch "\.(html|htm|js|css|webp|png|jpg|jpeg|gif|svg|ico|avif)$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "Thu, 01 Jan 1970 00:00:00 GMT"
  </FilesMatch>

  # Fontes — cache de 1 ano (nunca mudam)
  <FilesMatch "\.(woff|woff2|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

</IfModule>

# Compressão gzip
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript text/plain
</IfModule>
